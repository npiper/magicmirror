# check=skip=InvalidDefaultArgInFrom
ARG CI_REGISTRY_IMAGE BUILDER_TAG ALP_IMAGE
FROM ${CI_REGISTRY_IMAGE}:${BUILDER_TAG}_${TARGETARCH}_min_artifacts AS builder
FROM ${ALP_IMAGE} AS build-amd64
FROM ${ALP_IMAGE} AS build-arm64
FROM node:22-alpine AS build-arm
FROM build-${TARGETARCH}
LABEL maintainer="Karsten Hassel"

USER root

ENV MM_DIR=/opt/magic_mirror
WORKDIR $MM_DIR

COPY --from=builder --chmod=0777 --chown=node:node $MM_DIR $MM_DIR
# copy startscripts into container:
COPY --chmod=0777 --chown=node:node create_restore_script.sh entrypoint.sh health.sh $MM_DIR/
COPY --chmod=0777 --chown=node:node build_info.sh /tmp/

ARG GIT_INFO
RUN <<EOF
set -e
apk add --no-cache git nano tzdata tini coreutils
echo "#!/bin/sh" > /usr/local/bin/sudo
echo 'exec "$@"' >> /usr/local/bin/sudo
chmod +x *.sh /usr/local/bin/sudo
/tmp/build_info.sh "Runtime" "$GIT_INFO"
rm -f /tmp/build_info.sh
chown -R node:node $MM_DIR
EOF

USER node

ENV NODE_ENV=production \
    MM_OVERRIDE_DEFAULT_MODULES=true

EXPOSE 8080
HEALTHCHECK --timeout=10s --start-period=60s CMD ./health.sh

ENTRYPOINT ["/sbin/tini", "--", "./entrypoint.sh"]